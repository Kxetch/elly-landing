---
const faqs = [
  {
    q: "Is my data really private?",
    a: "Yes. SQLite lives on your disk. Diary entries, chat history, memories, and notes are encrypted at rest with Fernet. The only network calls elly ever makes are your chosen LLM API and Telegram, only if you explicitly enable it. No telemetry. No analytics. No cloud sync."
  },
  {
    q: "Do I need a GPU for local AI?",
    a: "No. Ollama runs CPU-only (slower but works). Cloud OpenAI is the default for quality; switch to Ollama for zero data egress. A modern CPU handles 7B-8B models fine for elly's tool-calling use cases."
  },
  {
    q: "What if I stop paying Patreon?",
    a: "You keep the last build forever. The AGPL-3.0 core remains free to self-host, build the PWA yourself and run docker compose up. Patreon funds polished binaries and frictionless updates, not the software."
  },
  {
    q: "Can I run this on a Raspberry Pi?",
    a: "Yes. Multi-arch Docker image (amd64 + arm64). docker compose up works on Pi 4/5 with 2GB+ RAM. Access via SSH tunnel or enable the Telegram bot for remote interaction."
  },
  {
    q: "How does Telegram remote access work?",
    a: "Pair once: Settings, Connect Telegram, send /start with the 6-digit code. Then chat with the bot from your phone to log habits, add tasks, or ask questions. Messages queue while your machine sleeps."
  },
  {
    q: "Is there a mobile app?",
    a: "The PWA installs to your home screen. iOS Safari Share, Add to Dock. Android Chrome, Install App. Works offline. Telegram bot is the intended remote interface."
  },
  {
    q: "What is AGPL-3.0?",
    a: "You can use, modify, and self-host freely. If you run a modified version as a public network service, you must offer users the modified source. Private self-hosting has no obligations beyond license notices."
  },
  {
    q: "How do I report a security issue?",
    a: "Use GitHub's private vulnerability reporting (Security tab). See SECURITY.md for the full threat model, scope, and response commitments."
  }
];
---

<section class="page-container section-spacer">

  <p class="eyebrow fade-in">FAQ</p>
  <h2 class="fade-in-up delay-1" style="max-width: 400px; margin-bottom: clamp(4rem, 8vw, 6rem);">
    Questions.
  </h2>

  <div class="section-narrow">
    {faqs.map((f, i) => (
      <details class={`fade-in-up delay-${Math.min(i + 2, 8)}`} style="border-bottom: 1px solid var(--color-border);">
        <summary style="padding: 1.5rem 0; cursor: pointer; font-size: 1rem; font-weight: 500; list-style: none; display: flex; justify-content: space-between; align-items: center;">
          {f.q}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" style="flex-shrink: 0; transition: transform 0.2s;">
            <path d="M4 6l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <div style="padding: 0 0 1.5rem 0;">
          <p style="font-size: 0.9375rem; line-height: 1.8;">{f.a}</p>
        </div>
      </details>
    ))}
  </div>
</section>

<script>
  document.querySelectorAll('details').forEach(d => {
    d.addEventListener('toggle', () => {
      const svg = d.querySelector('svg');
      if (svg) svg.style.transform = d.open ? 'rotate(180deg)' : '';
    });
  });
</script>
