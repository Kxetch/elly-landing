---
<section class="page-container section-spacer" data-orb="1">
  <div class="geo-divider">
    <span class="geo-circle" style="background: var(--color-geo-coral);"></span>
    <span class="geo-circle" style="background: var(--color-geo-amber);"></span>
    <span class="geo-circle" style="background: var(--color-geo-blue);"></span>
  </div>
  <div style="display: grid; grid-template-columns: 1fr 2fr; gap: clamp(3rem, 6vw, 5rem);">
    <div>
      <p class="eyebrow fade-in">safety</p>
      <h2 class="fade-in-up delay-1">The no-list.</h2>
    </div>
    <div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0;">
        <div class="fade-in-up delay-2" style="padding: 1rem 0; border-bottom: 1px solid var(--color-border); font-size: 1rem; color: var(--color-ink-secondary);">No ads</div>
        <div class="fade-in-up delay-3" style="padding: 1rem 0; border-bottom: 1px solid var(--color-border); font-size: 1rem; color: var(--color-ink-secondary);">No tracking</div>
        <div class="fade-in-up delay-4" style="padding: 1rem 0; border-bottom: 1px solid var(--color-border); font-size: 1rem; color: var(--color-ink-secondary);">No analytics</div>
        <div class="fade-in-up delay-5" style="padding: 1rem 0; border-bottom: 1px solid var(--color-border); font-size: 1rem; color: var(--color-ink-secondary);">No cloud sync</div>
        <div class="fade-in-up delay-6" style="padding: 1rem 0; border-bottom: 1px solid var(--color-border); font-size: 1rem; color: var(--color-ink-secondary);">No accounts</div>
        <div class="fade-in-up delay-7" style="padding: 1rem 0; border-bottom: 1px solid var(--color-border); font-size: 1rem; color: var(--color-ink-secondary);">No social features</div>
        <div class="fade-in-up delay-8" style="padding: 1rem 0; border-bottom: 1px solid var(--color-border); font-size: 1rem; color: var(--color-ink-secondary);">No camera access</div>
        <div class="fade-in-up delay-8" style="padding: 1rem 0; border-bottom: 1px solid var(--color-border); font-size: 1rem; color: var(--color-ink-secondary);">No microphone access</div>
        <div class="fade-in-up delay-8" style="padding: 1rem 0; border-bottom: 1px solid var(--color-border); font-size: 1rem; color: var(--color-ink-secondary);">No location data</div>
        <div class="fade-in-up delay-8" style="padding: 1rem 0; border-bottom: 1px solid var(--color-border); font-size: 1rem; color: var(--color-ink-secondary);">No data selling</div>
        <div class="fade-in-up delay-8" style="padding: 1rem 0; border-bottom: 1px solid var(--color-border); font-size: 1rem; color: var(--color-ink-secondary);">No browser dependency</div>
        <div class="fade-in-up delay-8" style="padding: 1rem 0; border-bottom: 1px solid var(--color-border); font-size: 1rem; color: var(--color-ink-secondary);">No app store gatekeepers</div>
      </div>
      <div class="fade-in-up delay-8" style="margin-top: 3rem;">
        <p style="font-size: 0.9375rem; color: var(--color-ink-tertiary);">elly is designed for care, with care. Encrypted at rest. Local token auth via OS keyring. Loopback-only network binding, always. The dashboard never listens beyond your own machine.</p>
      </div>
    </div>
  </div>
</section>
