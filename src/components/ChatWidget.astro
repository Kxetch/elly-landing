---
---
<div id="chat-widget">
  <button id="chat-toggle" aria-label="Chat with elly assistant">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
  </button>
  <div id="chat-window" class="chat-hidden">
    <div id="chat-header">
      <div id="chat-header-left">
        <div id="chat-avatar">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a4 4 0 0 1 4 4v2a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z"></path>
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          </svg>
        </div>
        <div>
          <div id="chat-title">elly assistant</div>
          <div id="chat-subtitle">Ask about the app</div>
        </div>
      </div>
      <button id="chat-close" aria-label="Close chat">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div id="chat-messages">
      <div class="chat-msg bot">
        <div class="chat-msg-avatar">e</div>
        <div class="chat-msg-content">Hi! I'm elly's assistant. Ask me anything about the app, features, installation, or pricing.</div>
      </div>
    </div>
    <div id="chat-footer">
      <div id="chat-rate-info"></div>
      <form id="chat-form">
        <input type="text" id="chat-input" placeholder="Ask about elly..." maxlength="500" autocomplete="off" />
        <button type="submit" id="chat-send" aria-label="Send message">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>

<style is:global>
  #chat-widget {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 1000;
    font-family: var(--font-sans);
  }

  /* ── Toggle button ── */
  #chat-toggle {
    width: 52px;
    height: 52px;
    border-radius: 16px;
    background: var(--color-geo-blue);
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.15),
      0 0 0 0 rgba(37, 99, 235, 0);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  #chat-toggle:hover {
    transform: translateY(-2px);
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.2),
      0 0 0 4px rgba(37, 99, 235, 0.15);
  }
  #chat-toggle:active { transform: translateY(0) scale(0.96); }

  /* ── Window ── */
  #chat-window {
    position: absolute;
    bottom: 64px;
    right: 0;
    width: 380px;
    height: 520px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  #chat-window.chat-hidden {
    opacity: 0;
    transform: translateY(8px) scale(0.96);
    pointer-events: none;
  }

  /* ── Header ── */
  #chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-border);
  }
  #chat-header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  #chat-avatar {
    width: 32px;
    height: 32px;
    border-radius: 10px;
    background: var(--color-geo-blue);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.8125rem;
    flex-shrink: 0;
  }
  #chat-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.2;
  }
  #chat-subtitle {
    font-size: 0.75rem;
    color: var(--color-ink-tertiary);
    line-height: 1.2;
  }
  #chat-close {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-ink-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
  }
  #chat-close:hover {
    background: var(--color-border);
    color: var(--color-ink);
  }

  /* ── Messages ── */
  #chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    scroll-behavior: smooth;
  }
  #chat-messages::-webkit-scrollbar { width: 4px; }
  #chat-messages::-webkit-scrollbar-track { background: transparent; }
  #chat-messages::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 4px; }

  #chat-messages .chat-msg {
    display: flex;
    gap: 8px;
    max-width: 88%;
    animation: msgIn 0.2s ease;
  }
  @keyframes msgIn {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  #chat-messages .chat-msg.bot { align-self: flex-start; }
  #chat-messages .chat-msg.user { align-self: flex-end; flex-direction: row-reverse; }

  #chat-messages .chat-msg-avatar {
    width: 26px;
    height: 26px;
    border-radius: 8px;
    background: var(--color-geo-blue);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.6875rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  #chat-messages .chat-msg-content {
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-ink);
    background: var(--color-bg) !important;
    border: 1px solid var(--color-border) !important;
  }

  #chat-messages .chat-msg.bot .chat-msg-content {
    border-bottom-left-radius: 4px;
  }

  #chat-messages .chat-msg.user .chat-msg-content {
    background: var(--color-geo-blue) !important;
    color: #fff !important;
    border: none !important;
    border-bottom-right-radius: 4px;
  }

  #chat-messages .chat-msg.error .chat-msg-content {
    background: #fef2f2 !important;
    border: 1px solid #fecaca !important;
    color: #991b1b !important;
  }
  :root[data-theme="dark"] #chat-messages .chat-msg.error .chat-msg-content {
    background: #3b1111 !important;
    border-color: #5c1a1a !important;
    color: #fca5a5 !important;
  }

  /* Markdown formatting inside messages */
  #chat-messages .chat-msg-content p {
    color: inherit;
    font-size: inherit;
    line-height: inherit;
    margin: 0;
  }
  #chat-messages .chat-msg-content strong,
  #chat-messages .chat-msg-content b { font-weight: 600; }
  #chat-messages .chat-msg-content em,
  #chat-messages .chat-msg-content i { font-style: italic; }

  #chat-messages .chat-msg-content ul,
  #chat-messages .chat-msg-content ol {
    margin: 6px 0;
    padding-left: 18px;
  }
  #chat-messages .chat-msg-content li {
    margin: 3px 0;
    line-height: 1.5;
  }

  #chat-messages .chat-msg-content a {
    color: var(--color-geo-blue);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  #chat-messages .chat-msg.user .chat-msg-content a {
    color: #bfdbfe;
  }

  /* Typing indicator */
  .chat-typing {
    display: flex;
    gap: 8px;
    align-self: flex-start;
    align-items: center;
    max-width: 88%;
  }
  .chat-typing .chat-msg-avatar { margin-top: 0; }
  .chat-typing-dots {
    display: flex;
    gap: 4px;
    padding: 12px 16px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-bottom-left-radius: 4px;
  }
  .chat-typing-dots span {
    width: 5px;
    height: 5px;
    background: var(--color-ink-tertiary);
    border-radius: 50%;
    animation: dotPulse 1.4s ease-in-out infinite;
  }
  .chat-typing-dots span:nth-child(2) { animation-delay: 0.15s; }
  .chat-typing-dots span:nth-child(3) { animation-delay: 0.3s; }

  @keyframes dotPulse {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.35; }
    30%           { transform: translateY(-3px); opacity: 1; }
  }

  /* ── Footer / input ── */
  #chat-footer {
    padding: 12px 14px 14px;
    border-top: 1px solid var(--color-border);
  }
  #chat-rate-info {
    font-size: 0.6875rem;
    color: var(--color-ink-tertiary);
    margin-bottom: 8px;
    min-height: 1em;
    padding: 0 2px;
  }
  #chat-form {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  #chat-input {
    flex: 1;
    height: 40px;
    padding: 0 14px;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-bg);
    color: var(--color-ink);
    font-size: 0.875rem;
    font-family: var(--font-sans);
    outline: none;
    transition: border-color 0.15s;
  }
  #chat-input::placeholder { color: var(--color-ink-tertiary); }
  #chat-input:focus { border-color: var(--color-geo-blue); }

  #chat-send {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--color-geo-blue);
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.15s, transform 0.1s;
  }
  #chat-send:hover { background: var(--color-geo-blue-hover); }
  #chat-send:active { transform: scale(0.94); }
  #chat-send:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

  @media (max-width: 480px) {
    #chat-widget { bottom: 16px; right: 16px; }
    #chat-window {
      width: calc(100vw - 32px);
      right: -8px;
      height: 70vh;
    }
  }
</style>

<script>
  import { renderMarkdown as renderMarkdownBase } from '../lib/markdown';

  const toggle = document.getElementById('chat-toggle')!;
  const chatWindow = document.getElementById('chat-window')!;
  const closeBtn = document.getElementById('chat-close')!;
  const form = document.getElementById('chat-form') as HTMLFormElement;
  const input = document.getElementById('chat-input') as HTMLInputElement;
  const messages = document.getElementById('chat-messages')!;
  const rateInfo = document.getElementById('chat-rate-info')!;
  const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;

  let isOpen = false;
  let isLoading = false;

  function renderMarkdown(text: string): string {
    return renderMarkdownBase(text, window.location.href);
  }

  function toggleChat() {
    isOpen = !isOpen;
    chatWindow.classList.toggle('chat-hidden', !isOpen);
    if (isOpen) input.focus();
  }

  function addMessage(text: string, type: 'user' | 'bot' | 'error') {
    const wrapper = document.createElement('div');
    wrapper.className = `chat-msg ${type}`;

    if (type === 'bot' || type === 'error') {
      const avatar = document.createElement('div');
      avatar.className = 'chat-msg-avatar';
      avatar.textContent = 'e';
      wrapper.appendChild(avatar);
    }

    const content = document.createElement('div');
    content.className = 'chat-msg-content';

    if (type === 'user') {
      content.textContent = text;
    } else if (type === 'bot') {
      content.innerHTML = renderMarkdown(text);
    } else {
      content.textContent = text;
    }

    wrapper.appendChild(content);
    messages.appendChild(wrapper);
    messages.scrollTop = messages.scrollHeight;
  }

  function showTyping() {
    const div = document.createElement('div');
    div.className = 'chat-typing';
    div.id = 'typing-indicator';
    div.innerHTML = `
      <div class="chat-msg-avatar">e</div>
      <div class="chat-typing-dots"><span></span><span></span><span></span></div>
    `;
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function removeTyping() {
    document.getElementById('typing-indicator')?.remove();
  }

  toggle.addEventListener('click', toggleChat);
  closeBtn.addEventListener('click', toggleChat);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const message = input.value.trim();
    if (!message || isLoading) return;

    addMessage(message, 'user');
    input.value = '';
    isLoading = true;
    sendBtn.disabled = true;
    showTyping();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message })
      });
      const data = await res.json() as {
        reply?: string;
        error?: string;
        resetIn?: number;
        remaining?: number;
      };
      removeTyping();

      if (res.status === 429) {
        addMessage(`Rate limit reached. Try again in ${data.resetIn || 60} minutes.`, 'error');
      } else if (!res.ok) {
        addMessage(data.error || 'Something went wrong.', 'error');
      } else {
        // Belt-and-suspenders: res.ok with no reply shouldn't happen
        // (the route always sends an error status when it has no
        // reply to send), but never render the literal string
        // "undefined" if it somehow does.
        addMessage(data.reply || 'Something went wrong.', 'bot');
        if (data.remaining !== undefined) {
          rateInfo.textContent = `${data.remaining} questions remaining this hour`;
        }
      }
    } catch {
      removeTyping();
      addMessage('Network error. Check your connection.', 'error');
    } finally {
      isLoading = false;
      sendBtn.disabled = false;
      input.focus();
    }
  });
</script>
