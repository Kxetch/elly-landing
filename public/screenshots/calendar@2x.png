<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="600" fill="#f5f0e6"/>
  <rect x="50" y="50" width="700" height="500" rx="16" fill="rgba(255,255,255,0.6)" stroke="rgba(255,255,255,0.5)" stroke-width="1"/>
  <text x="400" y="120" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="24" fill="#2f5c54" text-anchor="middle" font-weight="600">Calendar</text>
  <text x="400" y="160" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="14" fill="#6b6255" text-anchor="middle">Placeholder — replace with real 2× screenshot</text>
  
  <!-- Month grid -->
  <g font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="11" fill="#6b6255">
    <text x="130" y="220" text-anchor="middle">Mon</text>
    <text x="230" y="220" text-anchor="middle">Tue</text>
    <text x="330" y="220" text-anchor="middle">Wed</text>
    <text x="430" y="220" text-anchor="middle">Thu</text>
    <text x="530" y="220" text-anchor="middle">Fri</text>
    <text x="630" y="220" text-anchor="middle">Sat</text>
    <text x="730" y="220" text-anchor="middle">Sun</text>
  </g>
  
  <!-- Sample day cells -->
  <rect x="100" y="230" width="90" height="80" rx="8" fill="rgba(255,255,255,0.8)" stroke="rgba(255,255,255,0.5)"/>
  <text x="145" y="250" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="16" fill="#2b2620" text-anchor="middle">15</text>
  <rect x="115" y="265" width="60" height="10" rx="4" fill="#2f5c54" opacity="0.3"/>
  <rect x="115" y="280" width="60" height="10" rx="4" fill="#c97b56" opacity="0.3"/>
</svg>