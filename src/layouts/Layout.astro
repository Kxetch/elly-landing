---
interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description || "Self-hosted AI notebook. Notes, diary, calendar, habits, tasks. Local-first. Your data, yours."} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
:root {
  --hue: 232;
  --color-bg: hsl(232, 25%, 97%);
  --color-bg-warm: hsl(232, 20%, 94%);
  --color-surface: hsl(232, 22%, 100%);
  --color-ink: hsl(232, 40%, 16%);
  --color-ink-secondary: hsl(232, 25%, 38%);
  --color-ink-tertiary: hsl(232, 18%, 56%);
  --color-accent: hsl(232, 45%, 42%);
  --color-accent-light: hsl(232, 40%, 65%);
  --color-accent-subtle: hsl(232, 30%, 90%);
  --color-border: hsl(232, 20%, 88%);
  --color-border-light: hsl(232, 18%, 93%);
  --font-sans: "DM Sans", system-ui, sans-serif;
  --font-serif: "DM Serif Display", Georgia, serif;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

html {
  scroll-behavior: smooth;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  font-family: var(--font-sans);
  color: var(--color-ink);
  background: var(--color-bg);
  line-height: 1.7;
  font-size: 16px;
  letter-spacing: -0.01em;
  min-height: 100vh;
}

::selection {
  background: var(--color-accent);
  color: #fff;
}

:focus-visible {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
}

h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-serif);
  font-weight: 400;
  letter-spacing: -0.01em;
  line-height: 1.1;
  color: var(--color-ink);
}

h1 { font-size: clamp(3rem, 8vw, 6.5rem); letter-spacing: -0.02em; }
h2 { font-size: clamp(2rem, 4vw, 3.5rem); }
h3 { font-size: clamp(1.25rem, 2vw, 1.5rem); font-family: var(--font-sans); font-weight: 600; }
h4 { font-size: 1.125rem; font-family: var(--font-sans); font-weight: 600; }

p {
  color: var(--color-ink-secondary);
  line-height: 1.8;
  font-size: 1.0625rem;
}

a {
  color: var(--color-accent);
  text-decoration: none;
  transition: all 0.3s;
}

a:hover {
  color: var(--color-ink);
}

.page-container {
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 2rem;
}

@media (min-width: 768px) {
  .page-container { padding: 0 4rem; }
}

.section-spacer {
  padding: clamp(5rem, 12vw, 10rem) 0;
}

.section-narrow {
  max-width: 640px;
  margin: 0 auto;
}

.section-wide {
  max-width: 1080px;
  margin: 0 auto;
}

.eyebrow {
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 1.5rem;
  font-family: var(--font-sans);
}

.body-large {
  font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
  color: var(--color-ink-secondary);
  line-height: 1.8;
}

.body-small {
  font-size: 0.875rem;
  color: var(--color-ink-tertiary);
  line-height: 1.7;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.875rem 2rem;
  font-family: var(--font-sans);
  font-size: 0.875rem;
  font-weight: 500;
  letter-spacing: 0.01em;
  color: #fff;
  background: var(--color-accent);
  border: 1px solid var(--color-accent);
  border-radius: 100px;
  cursor: pointer;
  transition: all 0.3s;
  text-decoration: none;
}

.btn-primary:hover {
  background: var(--color-ink);
  color: #fff;
  border-color: var(--color-ink);
}

.btn-primary:active { transform: scale(0.98); }

.btn-ghost {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.875rem 2rem;
  font-family: var(--font-sans);
  font-size: 0.875rem;
  font-weight: 500;
  letter-spacing: 0.01em;
  color: var(--color-ink);
  background: transparent;
  border: 1px solid var(--color-border);
  border-radius: 100px;
  cursor: pointer;
  transition: all 0.3s;
  text-decoration: none;
}

.btn-ghost:hover {
  background: var(--color-accent-subtle);
  border-color: var(--color-accent-light);
  color: var(--color-accent);
}

.btn-ghost:active { transform: scale(0.98); }

.section-rule {
  width: 48px;
  height: 3px;
  background: var(--color-accent);
  margin-bottom: clamp(3rem, 6vw, 5rem);
  border-radius: 2px;
}

.fade-in { animation: fadeIn 0.8s ease-out both; }
.fade-in-up { animation: fadeInUp 0.8s ease-out both; }
.fade-in-slow { animation: fadeIn 1.2s ease-out both; }

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(1.5rem); }
  to { opacity: 1; transform: translateY(0); }
}

.delay-1 { animation-delay: 100ms; }
.delay-2 { animation-delay: 200ms; }
.delay-3 { animation-delay: 300ms; }
.delay-4 { animation-delay: 400ms; }
.delay-5 { animation-delay: 500ms; }
.delay-6 { animation-delay: 600ms; }
.delay-7 { animation-delay: 700ms; }
.delay-8 { animation-delay: 800ms; }

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}
</style>
